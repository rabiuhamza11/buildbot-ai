## 🔐 Database Schema

### User Collection
```javascript
{
  _id: ObjectId,
  email: String (unique),
  password: String (hashed),
  fullName: String,
  phone: String,
  accountType: String (free|basic|professional),
  createdAt: Date,
  updatedAt: Date,
  lastLogin: Date,
  isActive: Boolean,
  preferences: {
    language: String,
    currency: String,
    notifications: Boolean
  }
}
```

### Plan Collection
```javascript
{
  _id: ObjectId,
  userId: ObjectId (ref: User),
  title: String,
  description: String,
  projectType: String,
  specifications: {
    length: Number,
    width: Number,
    height: Number,
    rooms: Number,
    bathrooms: Number,
    features: [String]
  },
  aiGenerated: {
    prompt: String,
    response: String,
    model: String,
    timestamp: Date
  },
  materials: [
    {
      name: String,
      quantity: Number,
      unit: String,
      unitCost: Number,
      totalCost: Number
    }
  ],
  estimatedCost: Number,
  status: String (draft|completed|archived),
  createdAt: Date,
  updatedAt: Date
}
```

### Payment Collection
```javascript
{
  _id: ObjectId,
  userId: ObjectId (ref: User),
  amount: Number,
  currency: String,
  status: String (pending|completed|failed),
  planId: ObjectId (ref: Plan),
  paymentMethod: String (card|transfer|mobile_money|ussd),
  transactionRef: String,
  paymentGateway: String (paystack|flutterwave),
  response: Object,
  createdAt: Date,
  updatedAt: Date
}
```

